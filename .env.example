# AI Judge — copy to .env.local and fill in secrets.
# Never commit .env.local.
#
# AI_JUDGE_MODE — force BYOK policy (optional; easiest way to test prod UX locally):
#   unset / empty → follow NODE_ENV (next dev = env-key fallback, next start = BYOK)
#   AI_JUDGE_MODE=dev  → always allow OPENROUTER_API_KEY from this file
#   AI_JUDGE_MODE=prod → require browser key (ignore env key) — even under next dev
#
# OPENROUTER_API_KEY is optional:
#   - AI_JUDGE_MODE=dev (default under next dev): used when the browser has no key
#   - AI_JUDGE_MODE=prod: ignored. Users paste their key in Settings (localStorage)

AI_JUDGE_MODE=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_PATH=./data/ai-judge.sqlite
